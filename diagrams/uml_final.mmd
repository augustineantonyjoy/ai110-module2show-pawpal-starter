classDiagram
    %% PawPal+ final UML (Phase 6). Reflects the implemented pawpal_system.py.

    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +date due_date
        +mark_complete() None
        +next_occurrence() Optional~Task~
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task) None
        +get_tasks() List~Task~
        +complete_task(task) None
    }

    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet) None
        +get_all_tasks() List~Task~
    }

    class Scheduler {
        +Owner owner
        +get_today_schedule() List~Task~
        +sort_by_time(tasks) List~Task~
        +filter_tasks(tasks, pet_name, completed) List~Task~
        +detect_conflicts(tasks) List~str~
    }

    Owner "1" --> "many" Pet : manages
    Pet "1" --> "many" Task : has
    Scheduler "1" --> "1" Owner : organizes
    Task "1" ..> "0..1" Task : next_occurrence() creates
